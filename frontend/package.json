    "@radix-ui/react-toggle": "^1.1.7",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@tanstack/react-query": "^5.70.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.5.0",
